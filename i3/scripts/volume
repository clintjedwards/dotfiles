#!/usr/bin/env bash
set -euo pipefail

SINK="@DEFAULT_SINK@"
STEP="${1:-5%}"

case "${BLOCK_BUTTON:-}" in
  3) pactl set-sink-mute "$SINK" toggle ;;
  4) pactl set-sink-volume "$SINK" "+${STEP}" && pactl set-sink-mute "$SINK" 0 ;;
  5) pactl set-sink-volume "$SINK" "-${STEP}" && pactl set-sink-mute "$SINK" 0 ;;
esac

if [[ "$(pactl get-sink-mute "$SINK")" == *yes* ]]; then
  echo "MUTE"
else
  pactl get-sink-volume "$SINK" | awk -F'/' 'NR==1 {gsub(/ /,"",$2); print $2; exit}'
fi
